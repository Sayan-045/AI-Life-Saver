# GEMINI API Keys for rotation
VITE_GEMINI_KEY_1=your_first_gemini_key
VITE_GEMINI_KEY_2=your_second_gemini_key  
VITE_GEMINI_KEY_3=your_third_gemini_key

# GROQ API Key
VITE_GROQ_API_KEY=your_groq_key

# GEMINI_API_KEY: Default Gemini API key (fallback if VITE_GEMINI_KEY_* are not set)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Groq API key for backend fallback calls
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
